// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cards                 CreditCard[]
  transactions          Transaction[]
  incomes               Income[]
  categories            Category[]
  preferences           UserPreferences?
  alerts                Alert[]
  bankStatements        BankStatement[]
  loans                 Loan[]
  persons               Person[]
  thirdPartyPurchases   ThirdPartyPurchase[]
  budgetLimits          BudgetLimit[]
  borrowerTypes         BorrowerType[]
  durationAdjustments   DurationAdjustment[]
  publicSimulatorConfig PublicSimulatorConfig?
  consultas360          Consulta360[]

  @@map("users")
}

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  currency      String @default("ARS")
  timezone      String @default("America/Argentina/Buenos_Aires")
  dashboardView String @default("simple") // "simple" | "advanced"

  notifyEmail Boolean @default(true)
  notifyPush  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ============================================================================
// CREDIT CARDS & BILLING CYCLES
// ============================================================================

model CreditCard {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name  String // "CIUDAD Visa", "BBVA Mastercard"
  bank  String // "CIUDAD", "BBVA", "GALICIA"
  brand String // "visa", "mastercard", "amex"
  last4 String? // Últimos 4 dígitos

  closingDay Int // Día de cierre por defecto (1-31)
  dueDay     Int // Día de vencimiento por defecto (1-31)

  creditLimit Decimal? @db.Decimal(12, 2)
  color       String? // Para UI (hex color)
  holderType  String   @default("additional") // "primary" | "additional"
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions        Transaction[]
  billingCycles       BillingCycle[]
  closingSchedules    CardClosingSchedule[]
  thirdPartyPurchases ThirdPartyPurchase[]

  @@index([userId])
  @@map("credit_cards")
}

model CardClosingSchedule {
  id     String     @id @default(cuid())
  cardId String
  card   CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  year  Int // 2025, 2026, etc.
  month Int // 1-12

  closingDay Int // Día específico de cierre (1-31)
  dueDay     Int // Día específico de vencimiento (1-31)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cardId, year, month])
  @@index([cardId])
  @@index([cardId, year])
  @@map("card_closing_schedules")
}

model BillingCycle {
  id     String     @id @default(cuid())
  cardId String
  card   CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  period    String // "2025-01", "2025-02" (YYYY-MM)
  closeDate DateTime // Fecha real de cierre
  dueDate   DateTime // Fecha real de vencimiento

  totalAmount Decimal? @db.Decimal(12, 2) // Cache: suma de installments
  paidAmount  Decimal  @default(0) @db.Decimal(12, 2)
  status      String   @default("open") // "open" | "closed" | "paid"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  installments Installment[]
  payments     Payment[]

  @@unique([cardId, period])
  @@index([cardId, period])
  @@index([cardId, status])
  @@index([dueDate])
  @@map("billing_cycles")
}

// ============================================================================
// TRANSACTIONS & INSTALLMENTS
// ============================================================================

model Transaction {
  id     String @id // ID personalizado del Excel
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Metodo de pago: credit_card, cash, transfer
  paymentMethod String @default("credit_card")

  // Solo requerido si paymentMethod = "credit_card"
  cardId String?
  card   CreditCard? @relation(fields: [cardId], references: [id], onDelete: Cascade)

  description  String
  totalAmount  Decimal  @db.Decimal(12, 2)
  purchaseDate DateTime

  installments Int @default(1) // Cantidad de cuotas (solo aplica a tarjeta)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  subcategoryId String?
  subcategory   SubCategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  // Tipo de gasto customizado (tu clasificación única)
  expenseType String? // "structural" | "emotional_recurrent" | "emotional_impulsive"

  // Compras para terceros
  isForThirdParty Boolean @default(false)
  thirdPartyId    String?

  notes String?

  // Sistema de anulación
  isVoided Boolean   @default(false)
  voidedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  installmentsList   Installment[]
  thirdPartyPurchase ThirdPartyPurchase?

  @@index([userId])
  @@index([cardId])
  @@index([purchaseDate])
  @@index([paymentMethod])
  @@map("transactions")
}

model Installment {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  billingCycleId String
  billingCycle   BillingCycle @relation(fields: [billingCycleId], references: [id], onDelete: Cascade)

  installmentNumber Int // 1, 2, 3, ..., N
  amount            Decimal  @db.Decimal(12, 2)
  impactDate        DateTime // Fecha en que impacta en el resumen (primer día del mes)

  isPaid Boolean   @default(false)
  paidAt DateTime?

  createdAt DateTime @default(now())

  @@index([transactionId])
  @@index([billingCycleId])
  @@index([billingCycleId, isPaid])
  @@index([impactDate])
  @@map("installments")
}

// ============================================================================
// INCOMES (INGRESOS)
// ============================================================================

model Income {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  description String
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime

  // Categorización
  category    String // "active_income" | "other_income"
  subcategory String? // "salary" | "asset_sale" | "third_party_transfer"

  // Si es recurrente (ej: sueldo mensual)
  isRecurring Boolean @default(false)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([category])
  @@map("incomes")
}

// ============================================================================
// CATEGORIES
// ============================================================================

model Category {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name  String
  icon  String?
  color String?

  createdAt DateTime @default(now())

  // Relations
  subcategories SubCategory[]
  transactions  Transaction[]
  budgetLimits  BudgetLimit[]

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model SubCategory {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name String

  createdAt DateTime @default(now())

  // Relations
  transactions Transaction[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@map("subcategories")
}

// ============================================================================
// PAYMENTS
// ============================================================================

model Payment {
  id             String       @id @default(cuid())
  userId         String
  billingCycleId String
  billingCycle   BillingCycle @relation(fields: [billingCycleId], references: [id], onDelete: Cascade)

  amount        Decimal  @db.Decimal(12, 2)
  paymentDate   DateTime
  paymentMethod String? // "debit", "transfer", "cash"

  notes String?

  createdAt DateTime @default(now())

  @@index([billingCycleId])
  @@map("payments")
}

// ============================================================================
// BANK STATEMENTS & COMPARISON
// ============================================================================

model BankStatement {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cardId String

  period     String // "2025-01"
  importedAt DateTime @default(now())

  bankTotal       Decimal @db.Decimal(12, 2)
  calculatedTotal Decimal @db.Decimal(12, 2)
  discrepancy     Decimal @db.Decimal(12, 2) // bankTotal - calculatedTotal

  lineItems Json // Array de items del banco

  matchedCount   Int @default(0)
  unmatchedCount Int @default(0)

  @@index([userId])
  @@index([cardId, period])
  @@map("bank_statements")
}

// ============================================================================
// PERSONAL LOANS
// ============================================================================

model Person {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identificación
  name         String
  alias        String?
  cuit         String? // CUIT/CUIL/CDI sin guiones (11 dígitos), opcional
  relationship String  @default("conocido") // "amigo" | "amigo_de_amigo" | "conocido"
  referrer     String? // Quien lo refiere

  // Perfil económico
  incomeType      String   @default("informal") // "en_blanco" | "monotributo" | "informal"
  sector          String?
  tenureMonths    Int? // Antigüedad laboral en meses
  estimatedIncome Decimal? @db.Decimal(12, 2)

  // Estabilidad
  livesAlone       Boolean @default(false)
  hasChildren      Boolean @default(false)
  recentJobChanges Boolean @default(false)
  previousDebts    Boolean @default(false)

  // Comportamiento (1-5)
  punctualityScore   Int @default(3)
  communicationScore Int @default(3)
  debtAttitudeScore  Int @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  loans               Loan[]
  collectedLoans      Loan[]               @relation("LoanCollector")
  thirdPartyPurchases ThirdPartyPurchase[]
  consultas360        Consulta360[]

  @@index([userId])
  @@index([userId, cuit])
  @@map("persons")
}

model Loan {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  personId String?
  person   Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  collectorId String?
  collector   Person? @relation("LoanCollector", fields: [collectorId], references: [id], onDelete: SetNull)

  borrowerName      String // Nombre/alias del deudor (legado: para préstamos sin Persona vinculada)
  concept           String? // Concepto/destino del préstamo (ej: "consumo", "auto"). Solo cuando hay Persona vinculada.
  capital           Decimal  @db.Decimal(12, 2)
  currency          String   @default("ARS") // "ARS" | "USD" | "EUR"
  loanType          String   @default("amortized") // "amortized" | "interest_only"
  tna               Decimal  @db.Decimal(8, 6) // TNA como decimal (ej: 0.55)
  rateIsNominal     Boolean  @default(false) // true = tna es TNA nominal (nueva lógica); false = tna es TEA (legado)
  termMonths        Int? // null for interest_only loans
  monthlyRate       Decimal  @db.Decimal(10, 8)
  installmentAmount Decimal  @db.Decimal(12, 2)
  totalAmount       Decimal? @db.Decimal(12, 2) // null for interest_only loans
  startDate         DateTime
  status            String   @default("active") // "active" | "completed" | "defaulted" | "pre_approved" | "refinanced"

  // Refinancing
  refinancedByLoanId String? // ID del nuevo préstamo que reemplaza a este
  originalLoanId     String? // ID del préstamo original que fue refinanciado

  // Direction: lender (soy prestamista) or borrower (soy deudor)
  direction    String  @default("lender") // "lender" | "borrower"
  creditorName String? // Nombre del acreedor (cuando direction=borrower)

  // Phase 1 loan accounting metrics
  principalOutstanding       Decimal   @default(0) @db.Decimal(12, 2)
  overdueInterestOutstanding Decimal   @default(0) @db.Decimal(12, 2)
  irrContractualAnnual       Decimal?  @db.Decimal(12, 8)
  irrRealAnnual              Decimal?  @db.Decimal(12, 8)
  irrSlippageBps             Int?
  irrStatus                  String    @default("insufficient_flows") // "ok" | "insufficient_flows" | "no_convergence"
  irrCalculatedAt            DateTime?
  cashflowRevision           Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  loanInstallments LoanInstallment[]
  activityLogs     LoanActivityLog[]
  loanPayments     LoanPayment[]
  realCashflows    LoanRealCashflow[]
  monthlyAccruals  LoanAccrualMonthly[]
  attachments      LoanAttachment[]

  @@index([userId])
  @@index([userId, status])
  @@index([personId])
  @@index([collectorId])
  @@map("loans")
}

model LoanInstallment {
  id     String @id @default(cuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  number    Int // 1, 2, 3, ..., N
  dueDate   DateTime
  amount    Decimal  @db.Decimal(12, 2) // Cuota total
  interest  Decimal  @db.Decimal(12, 2) // Parte de interés
  principal Decimal  @db.Decimal(12, 2) // Parte de capital
  balance   Decimal  @db.Decimal(12, 2) // Saldo restante después de esta cuota

  isPaid     Boolean   @default(false)
  paidAt     DateTime?
  paidAmount Decimal   @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([loanId])
  @@index([loanId, isPaid])
  @@index([dueDate])
  @@map("loan_installments")
}

model LoanPayment {
  id          String   @id @default(cuid())
  loanId      String
  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  paymentDate DateTime
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("ARS")
  note        String?
  externalRef String?

  createdAt DateTime @default(now())

  realCashflows LoanRealCashflow[]

  @@unique([loanId, externalRef])
  @@index([loanId, paymentDate])
  @@map("loan_payments")
}

model LoanRealCashflow {
  id           String       @id @default(cuid())
  loanId       String
  loan         Loan         @relation(fields: [loanId], references: [id], onDelete: Cascade)
  paymentId    String?
  payment      LoanPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  flowDate     DateTime
  amountSigned Decimal      @db.Decimal(12, 2)
  component    String // "disbursement" | "interest_overdue" | "interest_current" | "principal" | ...

  createdAt DateTime @default(now())

  @@index([loanId, flowDate, id])
  @@index([paymentId])
  @@map("loan_real_cashflows")
}

model LoanAccrualMonthly {
  id                       String  @id @default(cuid())
  loanId                   String
  loan                     Loan    @relation(fields: [loanId], references: [id], onDelete: Cascade)
  year                     Int
  month                    Int
  openingPrincipal         Decimal @db.Decimal(12, 2)
  interestExpected         Decimal @db.Decimal(12, 2)
  interestCollectedCurrent Decimal @db.Decimal(12, 2)
  overdueInterestOpening   Decimal @db.Decimal(12, 2)
  overdueInterestGenerated Decimal @db.Decimal(12, 2)
  overdueInterestCollected Decimal @db.Decimal(12, 2)
  overdueInterestClosing   Decimal @db.Decimal(12, 2)
  principalCollected       Decimal @db.Decimal(12, 2)
  closingPrincipal         Decimal @db.Decimal(12, 2)
  deviationAmount          Decimal @db.Decimal(12, 2)
  deviationPct             Decimal @db.Decimal(10, 6)
  status                   String  @default("idle")

  updatedAt DateTime @updatedAt

  @@unique([loanId, year, month])
  @@index([loanId, year, month])
  @@map("loan_accruals_monthly")
}

// ============================================================================
// ALERTS
// ============================================================================

model Alert {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type   String // "closing_date" | "due_date" | "high_spending" | "limit_approaching"
  cardId String?

  threshold  Decimal? @db.Decimal(12, 2)
  daysBefore Int? // Para alertas de fecha

  isEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("alerts")
}

// ============================================================================
// THIRD-PARTY PURCHASES (COMPRAS DE TERCEROS)
// ============================================================================

model ThirdPartyPurchase {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  description String
  personId    String?
  person      Person? @relation(fields: [personId], references: [id], onDelete: SetNull)
  personName  String // Nombre libre (por si no hay Person)

  cardId String
  card   CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  totalAmount       Decimal @db.Decimal(12, 2)
  installments      Int     @default(1)
  installmentAmount Decimal @db.Decimal(12, 2)
  currency          String  @default("ARS") // "ARS" | "USD"

  purchaseDate DateTime
  firstDueDate DateTime?
  status       String    @default("active") // "active" | "completed"
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  collectionInstallments ThirdPartyInstallment[]

  @@index([userId])
  @@index([userId, status])
  @@index([cardId])
  @@map("third_party_purchases")
}

model ThirdPartyInstallment {
  id                   String             @id @default(cuid())
  thirdPartyPurchaseId String
  thirdPartyPurchase   ThirdPartyPurchase @relation(fields: [thirdPartyPurchaseId], references: [id], onDelete: Cascade)

  number  Int // 1, 2, 3, ..., N
  amount  Decimal  @db.Decimal(12, 2)
  dueDate DateTime

  isCollected     Boolean   @default(false)
  collectedAt     DateTime?
  collectionNotes String?

  createdAt DateTime @default(now())

  @@index([thirdPartyPurchaseId])
  @@index([thirdPartyPurchaseId, isCollected])
  @@index([dueDate])
  @@map("third_party_installments")
}

// ============================================================================
// LOAN ATTACHMENTS
// ============================================================================

model LoanAttachment {
  id     String @id @default(cuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  type     String // "transfer_receipt" | "pagare" | "mutual" | "other"
  fileName String
  fileUrl  String
  fileSize Int?
  mimeType String?

  createdAt DateTime @default(now())

  @@index([loanId])
  @@map("loan_attachments")
}

// ============================================================================
// LOAN ACTIVITY LOGS
// ============================================================================

model LoanActivityLog {
  id      String   @id @default(cuid())
  loanId  String
  loan    Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  userId  String
  note    String
  tag     String   @default("otro") // "llamada" | "pago" | "acuerdo" | "otro"
  logDate DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([loanId, logDate])
  @@map("loan_activity_logs")
}

// ============================================================================
// BUDGET LIMITS
// ============================================================================

model BudgetLimit {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  monthlyLimit Decimal  @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, categoryId])
  @@index([userId])
  @@map("budget_limits")
}

// ============================================================================
// LOAN RATE RULES
// ============================================================================

model BorrowerType {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name    String
  baseTna Decimal @db.Decimal(5, 2) // TNA mínima base (ej: 110.00 = 110%)
  order   Int     @default(0)

  publicSimulatorConfigs PublicSimulatorConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("borrower_types")
}

model DurationAdjustment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  minMonths  Int
  maxMonths  Int
  adjustment Decimal @db.Decimal(5, 2) // Ajuste en pp (ej: 10.00 = +10%)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("duration_adjustments")
}

// ============================================================================
// PUBLIC SIMULATOR CONFIG
// ============================================================================

model PublicSimulatorConfig {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tna            Decimal       @db.Decimal(5, 2) // TNA fija (usado cuando no hay tipo de prestatario)
  currency       String        @default("ARS") // ARS | USD
  terms          String        @default("3,6,9,12") // Plazos separados por coma
  whatsapp       String // Numero de WhatsApp (ej: 5491126369767)
  minCapital     Int           @default(50000) // Monto minimo del simulador
  maxCapital     Int           @default(20000000) // Monto maximo del simulador
  borrowerTypeId String? // Tipo de prestatario para la tasa base (opcional)
  borrowerType   BorrowerType? @relation(fields: [borrowerTypeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("public_simulator_configs")
}

// ============================================================================
// CONSULTA 360° (BCRA + AFIP credit report)
// ============================================================================

model Consulta360 {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  personId String?
  person   Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  cuit         String // 11 dígitos sin guiones
  denominacion String?

  // Resumen calculado
  score             Int // 0-1000
  riesgo            String // "bajo" | "medio" | "alto" | "critico"
  peorSituacion     Int? // 1-6 BCRA (null si sin datos)
  totalDeudaArs     Decimal @default(0) @db.Decimal(18, 2)
  cantEntidades     Int     @default(0)
  chequesRechazados Int     @default(0)
  mesesConDatos     Int     @default(0) // antigüedad en histórico
  scoreBreakdown    Json // { peorSit: {raw, weighted, ...}, ... }

  // Payloads crudos para auditoría / re-render
  payloadBcra      Json?
  payloadHistorico Json?
  payloadCheques   Json?
  payloadAfip      Json?

  // Estado de fuentes (qué se pudo consultar)
  bcraStatus String @default("ok") // "ok" | "not_found" | "error"
  afipStatus String @default("ok") // "ok" | "unavailable" | "error"

  observaciones String?

  consultadoEn DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, consultadoEn])
  @@index([userId, cuit])
  @@index([personId])
  @@map("consultas_360")
}

model Consulta360Cache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique // ej: "bcra:deudas:30500010912"
  source    String // "bcra_deudas" | "bcra_historicas" | "bcra_cheques" | "afip_padron"
  cuit      String
  payload   Json
  status    Int // HTTP status original
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([cuit])
  @@index([expiresAt])
  @@map("consulta_360_cache")
}
