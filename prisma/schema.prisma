// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cards         CreditCard[]
  transactions  Transaction[]
  incomes       Income[]
  categories    Category[]
  preferences   UserPreferences?
  alerts        Alert[]
  bankStatements BankStatement[]

  @@map("users")
}

model UserPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  currency       String  @default("ARS")
  timezone       String  @default("America/Argentina/Buenos_Aires")
  dashboardView  String  @default("simple") // "simple" | "advanced"
  
  notifyEmail    Boolean @default(true)
  notifyPush     Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ============================================================================
// CREDIT CARDS & BILLING CYCLES
// ============================================================================

model CreditCard {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String   // "CIUDAD Visa", "BBVA Mastercard"
  bank          String   // "CIUDAD", "BBVA", "GALICIA"
  brand         String   // "visa", "mastercard", "amex"
  last4         String?  // Últimos 4 dígitos
  
  closingDay    Int      // Día de cierre por defecto (1-31)
  dueDay        Int      // Día de vencimiento por defecto (1-31)
  
  creditLimit   Decimal? @db.Decimal(12, 2)
  color         String?  // Para UI (hex color)
  isActive      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions  Transaction[]
  billingCycles BillingCycle[]

  @@index([userId])
  @@map("credit_cards")
}

model BillingCycle {
  id        String   @id @default(cuid())
  cardId    String
  card      CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  period        String   // "2025-01", "2025-02" (YYYY-MM)
  closeDate     DateTime // Fecha real de cierre
  dueDate       DateTime // Fecha real de vencimiento
  
  totalAmount   Decimal? @db.Decimal(12, 2) // Cache: suma de installments
  paidAmount    Decimal  @default(0) @db.Decimal(12, 2)
  status        String   @default("open") // "open" | "closed" | "paid"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  installments Installment[]
  payments     Payment[]

  @@unique([cardId, period])
  @@index([cardId, period])
  @@map("billing_cycles")
}

// ============================================================================
// TRANSACTIONS & INSTALLMENTS
// ============================================================================

model Transaction {
  id        String   @id // ID personalizado del Excel
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Metodo de pago: credit_card, cash, transfer
  paymentMethod String   @default("credit_card")

  // Solo requerido si paymentMethod = "credit_card"
  cardId    String?
  card      CreditCard? @relation(fields: [cardId], references: [id], onDelete: Cascade)

  description   String
  totalAmount   Decimal    @db.Decimal(12, 2)
  purchaseDate  DateTime

  installments  Int        @default(1) // Cantidad de cuotas (solo aplica a tarjeta)

  categoryId    String?
  category      Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Tipo de gasto customizado (tu clasificación única)
  expenseType   String?    // "structural" | "emotional_recurrent" | "emotional_impulsive"

  // Compras para terceros
  isForThirdParty Boolean  @default(false)
  thirdPartyId    String?

  notes         String?

  // Sistema de anulación
  isVoided      Boolean    @default(false)
  voidedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  installmentsList Installment[]

  @@index([userId])
  @@index([cardId])
  @@index([purchaseDate])
  @@index([paymentMethod])
  @@map("transactions")
}

model Installment {
  id              String   @id @default(cuid())
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  billingCycleId  String
  billingCycle    BillingCycle @relation(fields: [billingCycleId], references: [id], onDelete: Cascade)
  
  installmentNumber Int      // 1, 2, 3, ..., N
  amount          Decimal    @db.Decimal(12, 2)
  impactDate      DateTime   // Fecha en que impacta en el resumen (primer día del mes)
  
  isPaid          Boolean    @default(false)
  paidAt          DateTime?
  
  createdAt DateTime @default(now())

  @@index([transactionId])
  @@index([billingCycleId])
  @@index([impactDate])
  @@map("installments")
}

// ============================================================================
// INCOMES (INGRESOS)
// ============================================================================

model Income {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  description   String
  amount        Decimal    @db.Decimal(12, 2)
  date          DateTime
  
  // Categorización
  category      String     // "active_income" | "other_income"
  subcategory   String?    // "salary" | "asset_sale" | "third_party_transfer"
  
  // Si es recurrente (ej: sueldo mensual)
  isRecurring   Boolean    @default(false)
  
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([category])
  @@map("incomes")
}

// ============================================================================
// CATEGORIES
// ============================================================================

model Category {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  icon          String?
  color         String?
  
  createdAt DateTime @default(now())

  // Relations
  subcategories SubCategory[]
  transactions  Transaction[]

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model SubCategory {
  id          String   @id @default(cuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name        String
  
  createdAt DateTime @default(now())

  @@unique([categoryId, name])
  @@index([categoryId])
  @@map("subcategories")
}

// ============================================================================
// PAYMENTS
// ============================================================================

model Payment {
  id              String   @id @default(cuid())
  userId          String
  billingCycleId  String
  billingCycle    BillingCycle @relation(fields: [billingCycleId], references: [id], onDelete: Cascade)

  amount          Decimal    @db.Decimal(12, 2)
  paymentDate     DateTime
  paymentMethod   String?    // "debit", "transfer", "cash"
  
  notes           String?

  createdAt DateTime @default(now())

  @@index([billingCycleId])
  @@map("payments")
}

// ============================================================================
// BANK STATEMENTS & COMPARISON
// ============================================================================

model BankStatement {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  cardId    String
  
  period          String     // "2025-01"
  importedAt      DateTime   @default(now())
  
  bankTotal       Decimal    @db.Decimal(12, 2)
  calculatedTotal Decimal    @db.Decimal(12, 2)
  discrepancy     Decimal    @db.Decimal(12, 2) // bankTotal - calculatedTotal
  
  lineItems       Json       // Array de items del banco
  
  matchedCount    Int        @default(0)
  unmatchedCount  Int        @default(0)

  @@index([userId])
  @@index([cardId, period])
  @@map("bank_statements")
}

// ============================================================================
// ALERTS
// ============================================================================

model Alert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type          String   // "closing_date" | "due_date" | "high_spending" | "limit_approaching"
  cardId        String?
  
  threshold     Decimal? @db.Decimal(12, 2)
  daysBefore    Int?     // Para alertas de fecha
  
  isEnabled     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("alerts")
}
